@model OrderFormVm

@{
    ViewData["Title"] = "Create Order";
}

<div class="card">

    <div class="card-header">
        <h4 class="mb-0">Create Order</h4>
        <small class="text-muted">
            Add products to create a sales order
        </small>
    </div>

    <div class="card-body">

        <div asp-validation-summary="All" class="text-danger"></div>

        <form id="order-form" asp-action="Create" method="post">
            <table id="items-table" class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;">#</th>
                        <th>Product</th>
                        <th style="width: 150px;">Quantity</th>
                        <th style="width: 120px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td class="row-number">1</td>

                        <td>
                            <select asp-for="Items[0].ProductId" class="form-select">
                                <option value="">
                                    Select Product
                                </option>

                                @foreach (var product in Model.Products)
                                {
                                    <option value="@product.Id">
                                        @product.Name
                                    </option>
                                }
                            </select>
                        </td>

                        <td>
                            <input asp-for="Items[0].Quantity" type="number" min="1" value="1" class="form-control" />
                        </td>

                        <td>
                            <button type="button" class="btn-sm btn-outline-danger remove-row">
                                Remove
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="text-end mb-3">
                <strong>
                    Total Items:
                    <span id="item-count">1</span>
                </strong>
            </div>

            <div class="mb-3">
                <button type="button" id="add-item" class="btn btb-secondary">
                    + Add Item
                </button>
            </div>

            <hr />

            <div class="d-flex gap-2">
                <button id="open-confirm-modal" type="button" class="btn btn-primary">
                    Create
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back
                </a>
            </div>

            <template id="product-options-template">
                <option value="">
                    Select Product
                </option>

                @foreach (var product in Model.Products)
                {
                    <option value="@product.Id">
                        @product.Name
                    </option>
                }
            </template>
        </form>

        @* ------------------- Confirm Create -------------------  *@
        <div id="confirmCreateModal" tabindex="-1" class="modal fade">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Order</h5>

                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        Are you sure you want to create this order?
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>

                        <button id="confirm-submit" type="button" class="btn btn-primary">Create</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/orders/create-order.js"></script>
}
