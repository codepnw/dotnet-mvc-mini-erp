@using System.Net.Mail
@model OrderIndexVm

@{
    ViewBag.Title = "Orders";
}

<div class="container-fluid mt-4">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Orders.Items.Any())
    {
        <div class="card shadow-sm">
            @* ------- Header ------- *@
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Orders</h5>

                <a asp-action="Create" class="btn btn-primary btn-sm">
                    Create Order
                </a>
            </div>

            @* ------- Body -------- *@
            <div class="card-body">

                 @* ----------- Search --------- *@
                <form action="" method="get">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <input type="text" name="Search" class="form-control form-control-sm" placeholder="Search by id, order number..."
                                   value="@Model.Query.Search" />
                        </div>

                        <div class="col-auto">
                            <button type="submit" class="btn btn-outline-primary btn-sm text-black">
                                Search
                            </button>
                        </div>
                    </div>
                </form>

                @* -------- Table Data -------- *@
                <table class="table table-hover align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th width="100">Order No</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th width="120">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Orders.Items)
                        {
                            <tr>
                                <td>@item.OrderNumber</td>
                                <td>@item.TotalAmount.ToString("N2")</td>
                                <td>@item.Status</td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                                @* ------ Actions ------ *@
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Confirm Delete Order?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>

                @* ------ Pagination ------ *@
                @if (Model.Orders.TotalPages > 1)
                {
                    <nav class="mt-3">
                        <ul class="pagination justify-content-center">
                            @* Previous *@
                            <li class="page-item @(Model.Orders.Page == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Orders.Page - 1)"
                                   asp-route-search="@Model.Query.Search">
                                    Previous
                                </a>
                            </li>

                            @* Page Number *@
                            @for (int i = 1; i <= Model.Orders.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Orders.Page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                                       asp-route-search="@Model.Query.Search">
                                        @i
                                    </a>
                                </li>
                            }

                            @* Next *@
                            <li class="page-item @(Model.Orders.Page == Model.Orders.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Orders.Page + 1)"
                                   asp-route-search="@Model.Query.Search">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                }

            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <h5>No Order Found</h5>

                <p class="text-muted">
                    Create your first order to get started
                </p>

                <a asp-action="Create" class="btn btn-primary">
                    Create Order
                </a>
            </div>
        </div>
    }

</div>