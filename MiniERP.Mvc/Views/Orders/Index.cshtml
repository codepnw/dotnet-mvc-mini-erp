@model OrderIndexVm

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Orders</h2>

    <a asp-action="Create" class="btn btn-primary">
        Create Order
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<table class="table table-bordered table-striped">

    <thead>

        <tr>
            <th>Order No</th>
            <th>Total Amount</th>
            <th>Status</th>
            <th>Created At</th>
            <th width="150">Actions</th>
        </tr>

    </thead>

    <tbody>

        @if (!Model.Orders.Items.Any())
        {
            <tr>
                <td colspan="5" class="text-center">
                    No orders found.
                </td>
            </tr>
        }

        @foreach (var order in Model.Orders.Items)
        {
            <tr>

                <td>
                    @order.OrderNumber
                </td>

                <td>
                    @order.TotalAmount.ToString("N2")
                </td>

                <td>
                    @order.Status
                </td>

                <td>
                    @order.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                </td>

                <td>

                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info">
                        Details
                    </a>

                </td>

            </tr>
        }
    </tbody>
</table>