@model LeaveRequestIndexVm

@{
    ViewBag.Title = "Leave Requests";
}

<div class="container mt-4">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Manage Leave Requests</h2>

        <a asp-controller="LeaveRequests"
           asp-action="Create"
           class="btn btn-primary">
            Create Leave Request
        </a>
    </div>

    @if (Model.LeaveRequests.Items.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>From Date</th>
                        <th>To Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var item in Model.LeaveRequests.Items)
                    {
                        <tr>
                            <td>@item.Id</td>

                            <td>
                                @item.FirstName @item.LastName
                            </td>

                            <td>
                                @item.LeaveTypeTitle
                            </td>

                            <td>
                                @item.FromDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.ToDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.Status
                            </td>

                            <td>
                                <a asp-controller="LeaveRequests"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                                <a asp-controller="LeaveRequests"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm text-white">
                                    Edit
                                </a>

                                <form asp-controller="LeaveRequests"
                                      asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this leave request?')">

                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>

                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            No leave requests found.
        </div>
    }

</div>
