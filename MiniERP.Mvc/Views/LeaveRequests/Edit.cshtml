@model LeaveRequestFormVm

@{
    ViewBag.Title = "Leave Request Edit";
    Layout = "_Layout";
}

<div class="container mt-4">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Edit Leave Request</h4>
        </div>

        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Edit"
                  asp-route-id="@Model.Id"
                  method="post">

                <input asp-for="Id" type="hidden"/>

                <div class="mb-3">
                    <strong>Employee:</strong>
                    <div>@Model.EmployeeName</div>
                </div>

                <div class="mb-3">
                    <strong>Leave Type:</strong>
                    <div>@Model.LeaveTypeTitle</div>
                </div>

                <div class="mb-3">
                    <strong>From Date:</strong>
                    <input asp-for="FromDate"
                           type="date"
                           class="form-control"/>
                    <span asp-validation-for="FromDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <strong>To Date:</strong>
                    <input asp-for="ToDate"
                           type="date"
                           class="form-control"/>
                    <span asp-validation-for="ToDate" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <strong>Reason:</strong>
                    <textarea asp-for="Reason"
                              rows="4"
                              class="form-control"></textarea>
                </div>

                <button type="submit" class="btn btn-success">
                    Update
                </button>

                <a asp-controller="LeaveRequests"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>
