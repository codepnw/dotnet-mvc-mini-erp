@model EmployeeEditVm

@{
    ViewBag.Title = "Edit Employee";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="card-header bg-warning">
            <h4 class="mb-0">Edit Employee</h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">

                <input asp-for="Id" type="hidden"/>

                <div class="mb-3">
                    <label class="form-label">FirstName</label>
                    <input asp-for="FirstName"
                           class="form-control"
                           placeholder="First Name"/>

                    <span asp-validation-for="FirstName"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">LastName</label>
                    <input asp-for="LastName"
                           class="form-control"
                           placeholder="Last Name"/>

                    <span asp-validation-for="LastName"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Salary</label>
                    <input asp-for="Salary"
                           type="number"
                           class="form-control"/>

                    <span asp-validation-for="Salary"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Department Id</label>
                    <input asp-for="DepartmentId"
                           type="number"
                           class="form-control"/>

                    <span asp-validation-for="DepartmentId"
                          class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <button type="submit"
                            class="btn btn-warning">
                        Update
                    </button>

                    <a asp-controller="Employees"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}