@model DepartmentIndexVm

@{
    ViewBag.Title = "Departments";
}

<div class="container-fluid mt-4">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Departments.Items.Any())
    {
        <div class="card shadow-sm">
            @* ---------- Header ----------- *@
            <div class="card-header d-flex justify-content-between aligh-items-center">
                <h5 class="mb-0">Departments</h5>

                <a asp-action="Create" class="btn btn-primary btn-sm">
                    Create Department
                </a>
            </div>

            @* ---------- Body ----------- *@
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th width="80">Id</th>
                            <th>Title</th>
                            <th width="140">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Departments.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Title</td>

                                @* ---------- Actions ----------- *@
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this department?')">

                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @* ---------- End Body ------------ *@
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <h5>No Departments Found</h5>

                <p class="text-muted">
                    Create your first department to get started
                </p>

                <a asp-action="Create" class="btn btn-primary">
                    Create Department
                </a>
            </div>
        </div>
    }

</div>