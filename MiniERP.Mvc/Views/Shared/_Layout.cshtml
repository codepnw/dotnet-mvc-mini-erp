@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniERP.Mvc</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiniERP.Mvc.styles.css" asp-append-version="true" />
</head>

<body>
    <div class="container-fluid">
        <div class="row min-vh-100">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Sidebar -->
                <div class="col-md-2 bg-white border-end shadow-sm p-3 min-vh-100">

                    <div class="mb-4">
                        <h4 class="fw-bold">
                            <i class="bi bi-box-seam"></i>
                            Mini ERP
                        </h4>

                        <small class="text-muted">Backoffice Management</small>
                    </div>

                    <ul class="nav flex-column">
                        <li class="nav-item mb-2">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-2"></i>
                                Dashboard
                            </a>
                        </li>

                        <li class="mt-4 text-uppercase small text-muted fw-bold">
                            HR
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="Index">
                                <i class="bi bi-people me-2"></i>
                                Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Employees" asp-action="Index">
                                <i class="bi bi-people me-2"></i>
                                Employees
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departments" asp-action="Index">
                                <i class="bi bi-diagram-3 me-2"></i>
                                Departments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="LeaveRequests" asp-action="Index">
                                <i class="bi bi-calendar-check me-2"></i>
                                Leave Requests
                            </a>
                        </li>

                        <li class="mt-4 text-uppercase small text-muted fw-bold">
                            Inventory
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categories" asp-action="Index">
                                <i class="bi bi-tags me-2"></i>
                                Categories
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-box me-2"></i>
                                Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ProductStocks" asp-action="LowStock">
                                <i class="bi bi-box me-2"></i>
                                Low Stock
                            </a>
                        </li>

                        <li class="mt-4 text-uppercase small text-muted fw-bold">
                            Sales
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(controller == "Orders" ? "active" : "")" asp-controller="Orders"
                               asp-action="Index">
                                <i class="bi bi-cart me-2"></i>
                                Order
                            </a>
                        </li>
                    </ul>

                    <div class="mt-auto">
                        <hr />

                        <div class="small text-muted">
                            Signed in as
                        </div>

                        <div class="fw-semibold mb-2">
                            @User.Identity?.Name
                        </div>

                        <form asp-controller="Users" asp-action="Logout" method="post">

                            <button class="btn btn-outline-danger w-100">
                                Logout
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Content -->
                <div class="col-md-10 p-4">
                    @RenderBody()
                </div>
            }
            else
            {
                <div class="col-12">
                    @RenderBody()
                </div>
            }
        </div>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3">

        <div id="app-toast" class="toast" rolw="alert">
            <div id="toast-header" class="toast-header">
                <strong id="toast-title" class="me-auto">Notification</strong>
            </div>

            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>

            <div class="toast-body"></div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
