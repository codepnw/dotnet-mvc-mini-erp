@model ProductFormVm

@{
    ViewBag.Title = "Create Product";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Edit Product</h4>
        </div>

        <div class="card-body">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Sku" class="form-label"></label>
                    <input asp-for="Sku" class="form-control" />
                    <span asp-validation-for="Sku" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MinimumStock" class="form-label"></label>
                    <input asp-for="MinimumStock" type="number" class="form-control" />
                </div>

                <div class="mb-4">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <input asp-for="CategoryId" type="number" class="form-control" />
                </div>

                <button asp-action="Edit" type="submit" class="btn btn-success">
                    Update
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}