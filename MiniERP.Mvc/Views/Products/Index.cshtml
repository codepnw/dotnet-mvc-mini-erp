@model ProductIndexVm

@{
    ViewBag.Title = "Products";
}

<div class="container mt-4">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Products.Items.Any())
    {
        <div class="card shadow-sm">
            @* -------- Header --------- *@
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Products</h5>

                <a asp-action="Create" class="btn btn-primary btn-sm">
                    Create Product
                </a>
            </div>

            @* -------- Body ----------- *@
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th width="80">Id</th>
                            <th>Name</th>
                            <th>SKU</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th width="180">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Products.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Sku</td>
                                <td>@item.Price.ToString("N2")</td>
                                <td>@item.Stock</td>

                                @* ----- Actions ------ *@
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Confirm Delete Product?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>

                                    <a asp-controller="ProductStocks" asp-action="Manage" asp-route-id="@item.Id" class="btn btn-dark btn-sm text-white">
                                        Stock
                                    </a>

                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <h5>No Products Found</h5>

                <p class="text-muted">
                    Create your first product to get started
                </p>

                <a asp-action="Create" class="btn btn-primary">
                    Create Product
                </a>
            </div>
        </div>
    }

</div>